{\n  "manifest_version": 3,\n  "name": "MCQ Auto Solver with Copilot",\n  "version": "1.0.0",\n  "description": "Automatically solve MCQ quizzes using GitHub Copilot API",\n  "permissions": ["scripting", "activeTab", "storage"],\n  "host_permissions": ["https://api.github.com/*"],\n  "action": {\n    "default_popup": "popup.html",\n    "default_title": "MCQ Auto Solver"\n  },\n  "background": {\n    "service_worker": "background.js"\n  }\n}